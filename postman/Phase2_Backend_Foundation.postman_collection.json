{
  "info": {
    "name": "College Event Management - Phase 2 Backend Foundation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "departmentId", "value": "" },
    { "key": "clubId", "value": "" },
    { "key": "categoryId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 200) {",
              "  const data = pm.response.json().data;",
              "  pm.collectionVariables.set('accessToken', data.accessToken);",
              "  pm.collectionVariables.set('refreshToken', data.refreshToken);",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"regNumber\": \"SA001\",\n  \"password\": \"ChangeMe123\"\n}"
            }
          }
        },
        {
          "name": "Login - Invalid credentials (expect 401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"regNumber\": \"SA001\",\n  \"password\": \"wrongpass\"\n}" }
          }
        },
        {
          "name": "Refresh Token",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 200) {",
              "  const data = pm.response.json().data;",
              "  pm.collectionVariables.set('accessToken', data.accessToken);",
              "  pm.collectionVariables.set('refreshToken', data.refreshToken);",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/refresh",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/logout",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Forgot Password (sends OTP email)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/forgot-password",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@campusconnect.edu\"\n}" }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/verify-otp",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@campusconnect.edu\",\n  \"otp\": \"123456\"\n}" }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/reset-password",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@campusconnect.edu\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"NewPassword123\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Register New User (Admin/Faculty Coordinator only)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 200) {",
              "  pm.collectionVariables.set('userId', pm.response.json().data.id);",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"regNumber\": \"STU2026001\",\n  \"name\": \"Test Student\",\n  \"email\": \"student1@campusconnect.edu\",\n  \"password\": \"Password123\",\n  \"role\": \"STUDENT\",\n  \"departmentId\": {{departmentId}}\n}"
            }
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/users?role=STUDENT"
          }
        },
        {
          "name": "Get User By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        },
        {
          "name": "Enable/Disable User (Super Admin only)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/users/{{userId}}/enabled?enabled=false"
          }
        },
        {
          "name": "Change User Role (Super Admin only)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/users/{{userId}}/role?role=STUDENT_ORGANIZER"
          }
        }
      ]
    },
    {
      "name": "Departments",
      "item": [
        {
          "name": "Create Department (Super Admin only)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 200) {",
              "  pm.collectionVariables.set('departmentId', pm.response.json().data.id);",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/departments",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Computer Science\",\n  \"code\": \"CSE\",\n  \"description\": \"Department of Computer Science and Engineering\"\n}" }
          }
        },
        {
          "name": "Update Department",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/departments/{{departmentId}}",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Computer Science & Engineering\",\n  \"code\": \"CSE\",\n  \"description\": \"Updated description\"\n}" }
          }
        },
        {
          "name": "List Departments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/departments"
          }
        },
        {
          "name": "Get Department By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/departments/{{departmentId}}"
          }
        },
        {
          "name": "Delete Department (Super Admin only)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/departments/{{departmentId}}"
          }
        }
      ]
    },
    {
      "name": "Clubs",
      "item": [
        {
          "name": "Create Club",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 200) {",
              "  pm.collectionVariables.set('clubId', pm.response.json().data.id);",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/clubs",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Coding Club\",\n  \"description\": \"For competitive programmers\",\n  \"departmentId\": {{departmentId}}\n}" }
          }
        },
        {
          "name": "Update Club",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/clubs/{{clubId}}",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Coding Club\",\n  \"description\": \"Updated description\",\n  \"departmentId\": {{departmentId}}\n}" }
          }
        },
        {
          "name": "Toggle Club Active",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/clubs/{{clubId}}/active?active=false"
          }
        },
        {
          "name": "List Clubs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/clubs"
          }
        },
        {
          "name": "Delete Club (Super Admin only)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/clubs/{{clubId}}"
          }
        }
      ]
    },
    {
      "name": "Event Categories",
      "item": [
        {
          "name": "Create Category",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 200) {",
              "  pm.collectionVariables.set('categoryId', pm.response.json().data.id);",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/event-categories",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Technical\",\n  \"description\": \"Hackathons, workshops, coding contests\"\n}" }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/event-categories/{{categoryId}}",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Technical\",\n  \"description\": \"Updated description\"\n}" }
          }
        },
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/event-categories"
          }
        },
        {
          "name": "Delete Category (Super Admin only)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/event-categories/{{categoryId}}"
          }
        }
      ]
    },
    {
      "name": "Audit Logs",
      "item": [
        {
          "name": "List Audit Logs (Super Admin only)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/audit-logs?page=0&size=20"
          }
        },
        {
          "name": "Filter Audit Logs by performedBy",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/audit-logs?performedBy=SA001"
          }
        }
      ]
    },
    {
      "name": "File Upload",
      "item": [
        {
          "name": "Upload File",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/files/upload",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Download File (public)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/files/download/REPLACE_WITH_STORED_FILE_NAME"
          }
        }
      ]
    }
  ]
}
